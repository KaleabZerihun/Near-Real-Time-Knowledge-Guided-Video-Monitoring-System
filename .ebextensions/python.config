# AWS Elastic Beanstalk configuration file for FastAPI backend
# Place this as .ebextensions/python.config in the project root

option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: "backend/main:app"
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.large  # Start with regular instance, upgrade to GPU later
    IamInstanceProfile: aws-elasticbeanstalk-ec2-role
  aws:elasticbeanstalk:application:environment:
    DATABASE_URL: "sqlite:////var/app/current/data/app.db"
    RUN_PIPELINE: "false"  # Disable pipeline initially for testing
    VIDEO_SOURCE: "0"
    TARGET_FPS: "8.0"
    ALLOWED_ORIGINS: "https://your-amplify-domain.amplifyapp.com"

commands:
  01_create_data_dir:
    command: "mkdir -p /var/app/current/data"
    ignoreErrors: true
  02_log_system_info:
    command: |
      echo "System Information:" >> /var/log/eb-activity.log
      uname -a >> /var/log/eb-activity.log
      python --version >> /var/log/eb-activity.log
      pip --version >> /var/log/eb-activity.log
    ignoreErrors: true
