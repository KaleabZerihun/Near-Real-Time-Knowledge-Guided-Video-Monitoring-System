packages:
  yum:
    git: []

option_settings:
  aws:elasticbeanstalk:command:
    Timeout: 1800
  aws:elasticbeanstalk:container:python:
    WSGIPath: "backend/main:app"
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.micro
    IamInstanceProfile: aws-elasticbeanstalk-ec2-role
    DisableIMDSv1: true
  aws:elasticbeanstalk:application:environment:
    DATABASE_URL: "sqlite:////var/app/current/data/app.db"
    RUN_PIPELINE: "true"
    VIDEO_SOURCE: "browser_upload"
    VIDEO_SOURCE_ID: "browser-upload"
    TARGET_FPS: "8.0"
    ALLOWED_ORIGINS: "https://main.dqa0nqc0y5bxy.amplifyapp.com"

commands:
  00_create_swap:
    command: |
      if ! /sbin/swapon --show | /bin/grep -q '^/swapfile'; then
        /usr/bin/fallocate -l 2G /swapfile || /bin/dd if=/dev/zero of=/swapfile bs=1M count=2048
        /bin/chmod 600 /swapfile
        /sbin/mkswap /swapfile
        /sbin/swapon /swapfile
        /bin/grep -q '^/swapfile' /etc/fstab || /bin/echo '/swapfile swap swap defaults 0 0' >> /etc/fstab
      fi
    ignoreErrors: true
  01_create_data_dir:
    command: "mkdir -p /var/app/current/data"
    ignoreErrors: true
  02_log_system_info:
    command: |
      echo "System Information:" >> /var/log/eb-activity.log
      uname -a >> /var/log/eb-activity.log
      python --version >> /var/log/eb-activity.log
      pip --version >> /var/log/eb-activity.log
    ignoreErrors: true
